# Core
SECRET_KEY=change-me
DEBUG=false
FRONTEND_URL=http://localhost
ALLOWED_ORIGINS=http://localhost

# Database
DB_USER=flowora
DB_PASSWORD=changeme
DB_NAME=flowora
DATABASE_URL=postgresql://flowora:changeme@pgbouncer:6432/flowora

# Redis + Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_MAX_QUEUE_SIZE=1000
CELERY_MAX_TASKS_PER_CHILD=100
CELERY_MAX_MEMORY_PER_CHILD_MB=512

# Object Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=flowora

# AI Runtime
DEFAULT_AI_PROVIDER=local
DEFAULT_AI_MODEL=qwen2.5:7b-instruct
OLLAMA_PRELOAD_MODEL=qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://ollama:11434
ALLOW_LLM_MOCK_FALLBACK=false
OLLAMA_CONNECT_TIMEOUT_SECONDS=5
OLLAMA_HEALTH_TIMEOUT_SECONDS=5
OLLAMA_RETRY_ATTEMPTS=6
OLLAMA_RETRY_BACKOFF_SECONDS=2
OLLAMA_TIMEOUT_SECONDS=110
OLLAMA_WARMUP_TIMEOUT_SECONDS=15
OLLAMA_MAX_CONCURRENCY=1
OLLAMA_QUEUE_MAX=4
REQUEST_TIMEOUT_SECONDS=120
AGENT_RUN_TIMEOUT_SECONDS=120
TIMEOUT_BUFFER_SECONDS=10
REFLECTION_TIMEOUT_SECONDS=10
EMAIL_VERIFICATION_REQUIRED=true
AUTO_VERIFY_EMAIL=true
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_SITE_URL=http://localhost
NEXT_PUBLIC_DEMO_AGENT_ID=

# Workflow limits
WORKFLOW_MAX_DEPTH=20
WORKFLOW_MAX_EXECUTION_SECONDS=120

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Logging
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=10
LOG_COMPRESS=true

# Safety
RATE_LIMIT_USER_PER_MINUTE=60
PROMPT_FILTER_ENABLED=true
PROMPT_MAX_CHARS=4000
PROMPT_BLOCKLIST=
