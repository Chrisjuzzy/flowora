# Flowora production environment
# Required: review every value before first public deploy.
# Recommended target: Fly.io with managed Postgres + managed Redis + managed LLM provider.

# -----------------------------------------------------------------------------
# Core app (required)
# -----------------------------------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=UInKQY8BcvWFBidkC4gZEJTfRHD0cMmWiKR7FcETxyeGU3PBoTZTq-ssEZolNzmO
EMAIL_VERIFICATION_REQUIRED=true
AUTO_VERIFY_EMAIL=false
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=30
ALLOW_LLM_MOCK_FALLBACK=false
RATE_LIMIT_USER_PER_MINUTE=60
PROMPT_FILTER_ENABLED=true
PROMPT_MAX_CHARS=4000

# -----------------------------------------------------------------------------
# Public routing / domain (required)
# -----------------------------------------------------------------------------
TRAEFIK_DOMAIN=flowora.ai
TRAEFIK_DASHBOARD_ENABLED=false
FRONTEND_URL=https://app.flowora.ai
ALLOWED_ORIGINS=https://app.flowora.ai,https://flowora.ai
NEXT_PUBLIC_API_URL=https://flowora.ai/api
NEXT_PUBLIC_SITE_URL=https://flowora.ai
NEXT_PUBLIC_DEMO_AGENT_ID=1

# -----------------------------------------------------------------------------
# Database - managed Postgres (required)
# Replace with your real managed Postgres connection string.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://flowora:<strong-db-password>@<managed-postgres-host>:5432/flowora
USE_PGVECTOR=false
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_STARTUP_MAX_ATTEMPTS=12
DATABASE_STARTUP_BACKOFF_SECONDS=2
DATABASE_STARTUP_MAX_BACKOFF_SECONDS=10

# -----------------------------------------------------------------------------
# Redis / Celery (required)
# Replace with your real managed Redis connection strings.
# -----------------------------------------------------------------------------
REDIS_URL=redis://default:<strong-redis-password>@<managed-redis-host>:6379/0
CELERY_BROKER_URL=redis://default:<strong-redis-password>@<managed-redis-host>:6379/1
CELERY_RESULT_BACKEND=redis://default:<strong-redis-password>@<managed-redis-host>:6379/2

# -----------------------------------------------------------------------------
# AI provider (required)
# Recommended for cloud: managed provider, not local Ollama.
# Choose ONE provider path.
# -----------------------------------------------------------------------------
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=<set-openai-api-key>
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
REQUEST_TIMEOUT_SECONDS=120
TIMEOUT_BUFFER_SECONDS=10
OLLAMA_TIMEOUT_SECONDS=110

# Optional local/GPU Ollama path - leave disabled in normal cloud deploys.
# If you deploy Ollama yourself, switch DEFAULT_AI_PROVIDER=local and set these.
OLLAMA_BASE_URL=http://ollama:11434

# -----------------------------------------------------------------------------
# Object storage (required if using self-hosted MinIO, otherwise set your S3-compatible endpoint)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=<s3-or-minio-endpoint>
MINIO_ACCESS_KEY=floworaadmin
MINIO_SECRET_KEY=mB6Eyr-N5dKIHpcEbzP9dunHxe7Tq5AzstgDuNANZrI
MINIO_BUCKET=flowora
MINIO_SECURE=true

# -----------------------------------------------------------------------------
# Email / SMTP (required for real email verification)
# -----------------------------------------------------------------------------
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASSWORD=<smtp-password>
FROM_EMAIL=noreply@flowora.ai

# -----------------------------------------------------------------------------
# Monitoring / observability (optional but recommended)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=TQdOy0OTFvhcTYW43-BjySOOy1faAJJX

# -----------------------------------------------------------------------------
# Image tags (optional)
# -----------------------------------------------------------------------------
FLOWORA_BACKEND_IMAGE=flowora-backend:latest
FLOWORA_FRONTEND_IMAGE=flowora-frontend:latest
