# ==================== APP CONFIGURATION ====================
APP_NAME=Flowora
DEBUG=false
API_V1_STR=/api/v1

# ==================== DATABASE ====================
# For development: SQLite (default)
# For production: Use PostgreSQL + pgvector
DATABASE_URL=postgresql://flowora:flowora@localhost:5432/flowora

# ==================== SECURITY ====================
# IMPORTANT: Generate a strong SECRET_KEY for production
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-use-256-bits-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== RATE LIMITING ====================
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=30
RATE_LIMIT_EXECUTION_PER_MINUTE=5

# ==================== CORS ====================
# Must be set to your frontend domain
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==================== EMAIL (SMTP) ====================
# Optional: If not set, email service will log warnings
# Gmail: smtp.gmail.com (use app password, not account password)
# SendGrid: smtp.sendgrid.net (port 587)
# AWS SES: email-smtp.region.amazonaws.com (port 587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@flowora.ai

# ==================== AI PROVIDERS ====================
DEFAULT_AI_PROVIDER=local
OLLAMA_BASE_URL=http://localhost:11434

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== OBJECT STORAGE (MINIO) ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=flowora
MINIO_SECURE=false

# ==================== FEATURE FLAGS ====================
ENABLE_MARKETPLACE=true
ENABLE_SCHEDULING=true
ENABLE_CODE_STUDIO=true

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=
